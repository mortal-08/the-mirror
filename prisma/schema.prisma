datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String      @id @default(uuid())
  name         String
  email        String      @unique
  passwordHash String
  entries      TimeEntry[]
  categories   Category[]
  tags         Tag[]
  goals        Goal[]
  journals     Journal[]
  todos        Todo[]
  routineBlocks RoutineBlock[]
  routineTemplates RoutineTemplate[]
  reflections  Reflection[]
  importantDates ImportantDate[]
  pushSubscriptions PushSubscription[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model Category {
  id        String      @id @default(uuid())
  name      String
  color     String      @default("#6366f1")
  icon      String      @default("folder")
  isProductive Boolean   @default(false)
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  entries   TimeEntry[]
  tags      Tag[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@unique([name, userId])
}

model Todo {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  task        String
  isCompleted Boolean  @default(false)
  targetDate  DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model RoutineBlock {
  id            String            @id @default(cuid())
  userId        String
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  planDate      DateTime          @db.Date
  task          String
  startMinutes  Int
  endMinutes    Int
  templateId    String?
  template      RoutineTemplate?  @relation(fields: [templateId], references: [id], onDelete: SetNull)
  notifyVersion Int               @default(1)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([userId, planDate])
}

model RoutineTemplate {
  id        String                @id @default(cuid())
  userId    String
  user      User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  days      Int[]                 // 0=Sun, 1=Mon, ..., 6=Sat
  isActive  Boolean               @default(true)
  blocks    RoutineTemplateBlock[]
  appliedBlocks RoutineBlock[]
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt

  @@index([userId])
}

model RoutineTemplateBlock {
  id           String          @id @default(cuid())
  templateId   String
  template     RoutineTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  task         String
  startMinutes Int
  endMinutes   Int

  @@index([templateId])
}

model Reflection {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date           DateTime @db.Date
  timeSlot       Int      // startMinutes value this reflection is for
  content        String
  routineBlockId String?  // optional link to the routine block
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([userId, date, timeSlot])
  @@index([userId, date])
}

model Tag {
  id        String      @id @default(uuid())
  name      String
  color     String      @default("#8b5cf6")
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  entries   TimeEntry[]
  categories Category[]
  createdAt DateTime    @default(now())

  @@unique([name, userId])
}

model TimeEntry {
  id              String    @id @default(uuid())
  description     String?
  startTime       DateTime
  endTime         DateTime?
  durationSeconds Int?
  categoryId      String?
  category        Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  tags            Tag[]
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Goal {
  id            String   @id @default(uuid())
  type          String   // "DAILY" or "WEEKLY"
  targetSeconds Int      @default(36000)
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([type, userId])
}

model Journal {
  id        String   @id @default(uuid())
  date      DateTime @db.Date
  content   String
  mood      String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([date, userId])
}

model ImportantDate {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  date        DateTime
  description String?
  color       String   @default("#f59e0b")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  cacheBuster Boolean @default(false)

  @@index([userId, date])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  timezone  String   @default("UTC")
  createdAt DateTime @default(now())

  @@index([userId])
}
